    app: eks-example


fluent-bit.yaml


apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: aws-for-fluent-bit
  namespace: kube-system
spec:
  interval: 30m
  chart:
    spec:
      chart: aws-for-fluent-bit
      version: "0.1.30"
      sourceRef:
        kind: HelmRepository
        name: aws-eks-charts
        namespace: flux-system
  values:
    serviceAccount:
      create: true
      name: fluent-bit
      annotations:
        eks.amazonaws.com/role-arn: "arn:aws:iam::956959394519:role/fluent-bit"

    cloudWatchLogs:
      enabled: false
    firehose:
      enabled: false
    kinesis:
      enabled: false

    opensearch:
      enabled: true
      host: "vpc-paulurbinatest-jsp7wwhkxdhsqrag7zight26ti.us-east-1.es.amazonaws.com"
      port: 443
      tls: "On"
      awsAuth: "On"
      awsRegion: "us-east-1"
      # --- ESTAS TRES LÍNEAS COMPLEMENTAN LA FIRMA SIGV4 CON EL ROL ---
      awsRoleARN: "arn:aws:iam::956959394519:role/fluent-bit"
      tlsVerify: "On"
      replaceDots: "On"
      # -----------------------------------------------------------------
      logstashPrefix: "kubernetes-logs"
      logstashFormat: "On"
      suppressTypeName: "On"

